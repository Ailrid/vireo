{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*"
  ],
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "composite": true,
    "types": [
      "electron-vite/node",
      "reflect-metadata"
    ],
    "paths": {
      "@main/*": [
        "./src/main/*"
      ],
    }
  }
}