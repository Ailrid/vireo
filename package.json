{
  "name": "starry",
  "version": "0.1.0",
  "description": "An Electron application with Vue and Virid",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "pnpm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:linux": "pnpm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@swc/core": "^1.15.11",
    "@tailwindcss/vite": "^4.1.18",
    "@virid/bridge": "link:../../virid/packages/bridge",
    "@virid/core": "link:../../virid/packages/core",
    "@virid/express": "link:../../virid/packages/express",
    "@virid/main": "link:../../virid/packages/main",
    "@virid/renderer": "link:../../virid/packages/renderer",
    "@virid/vue": "link:../../virid/packages/vue",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "cva": "^0.0.0",
    "electron-log": "^5.4.3",
    "express": "^5.2.1",
    "lucide-vue-next": "^0.562.0",
    "node-forge": "^1.3.3",
    "qrcode": "^1.5.4",
    "radix-vue": "^1.9.17",
    "reflect-metadata": "^0.2.2",
    "reka-ui": "^2.7.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "ts-pattern": "^5.9.0",
    "ts-results": "^3.3.0",
    "tw-animate-css": "^1.4.0",
    "uqr": "^0.1.2",
    "vue-router": "^5.0.1"
  },
  "build": {
    "appId": "Template",
    "productName": "Template",
    "copyright": "Copyright © 2025 Template",
    "compression": "maximum",
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "deb",
      "category": "Utility",
      "desktop": {
        "Name": "Template"
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": false
    }
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.7",
    "@types/node-forge": "^1.3.14",
    "@vitejs/plugin-vue": "^6.0.3",
    "electron": "^39.3.0",
    "electron-builder": "^26.4.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.7.0",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.97.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-swc-transform": "^1.1.1",
    "vue": "^3.5.27",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "vue-demi"
    ],
    "overrides": {
      "vite": "^7.3.0"
    }
  }
}
