{
  "name": "vireo",
  "version": "0.1.1",
  "description": "An Electron application with Vue and Virid",
  "main": "./out/main/index.js",
  "author": {
    "name": "Ailrid",
    "email": "ailrid.code@gmail.com"
  },
  "homepage": "https://github.com/Ailrid/vireo",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "pnpm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:linux": "pnpm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@swc/core": "^1.15.24",
    "@tailwindcss/vite": "^4.2.2",
    "@virid/bridge": "0.2.0",
    "@virid/core": "0.2.3",
    "@virid/express": "0.2.2",
    "@virid/main": "0.2.2",
    "@virid/renderer": "0.2.2",
    "@virid/vue": "0.2.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-vue-next": "^0.562.0",
    "reflect-metadata": "^0.2.2",
    "tailwindcss": "^4.2.2",
    "ts-pattern": "^5.9.0",
    "ts-results": "^3.3.0",
    "uqr": "^0.1.3",
    "vue-router": "^5.0.4"
  },
  "build": {
    "appId": "com.ailrid.vireo",
    "productName": "Vireo",
    "executableName": "Vireo",
    "copyright": "Copyright © 2026 Ailrid",
    "compression": "maximum",
    "asar": true,
    "protocols": [
      {
        "name": "Orpheus Protocol",
        "schemes": [
          "orpheus"
        ]
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json",
      "node_modules/better-sqlite3/**/*",
      "resources/**/*"
    ],
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "asInvoker"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "AudioVideo;Audio;Music;Player;",
      "mimeTypes": [
        "x-scheme-handler/vireo"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vireo"
    }
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.17",
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "^39.8.7",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-swc-transform": "^1.1.1",
    "vue": "^3.5.32",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "vue-demi"
    ],
    "overrides": {
      "vite": "^7.3.0"
    }
  }
}
